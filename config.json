  "storm": {
    "writes_per_second": 1000,
    "reads_per_second": 500,
    "doc_size_min": 1024,
    "doc_size_max": 10240,
    "workers": 16,
    "region": "us-east-1",
    "burst_enabled": false,
    "burst_multiplier": 3.0,
    "hot_key_percentage": 0.2,
    "delete_percentage": 0.05,
    "update_percentage": 0.30,
    "key_prefix": "nebula"
  },
  "upgrade": {
    "source_version": "7.2.2",
    "target_version": "7.6.5",
    "namespace": "couchbase",
    "cluster_name": "cb-local",
    "kubeconfig": "/Users/balinderwalia/.kube/k3s0.yaml",
    "helm_release": "couchbase-operator",
    "helm_chart": "couchbase/couchbase-operator",
    "max_unavailable": 1
  },
  "xdcr": {
    "poll_interval": 5000000000,
    "goxdcr_delay_alert": 300000000000
  },
  "validator": {
    "batch_size": 10000,
    "scan_interval": 30000000000,
    "hash_check": true,
    "sequence_check": true,
    "key_sampling": 1.0
  },
  "metrics": {
    "enabled": true,
    "endpoint": "/metrics",
    "port": 9090
  },
  "regions": [
    {
      "name": "us-east-1",
      "display_name": "US East (Virginia)",
      "provider": "aws",
      "clusters": ["cb-local"],
      "primary": true
    },
    {
      "name": "us-west-2",
      "display_name": "US West (Oregon)",
      "provider": "aws",
      "clusters": ["cb-test"],
      "primary": false
    }
  ],
  "failover": {
    "enabled": true,
    "auto_failover": false,
    "failover_timeout": 120000000000,
    "max_auto_failovers": 1,
    "health_check_interval": 10000000000,
    "recovery_mode": "manual",
    "preserve_data": true
  },
  "backup": {
    "enabled": true,
    "schedule": "0 2 * * *",
    "repository": "/tmp/nebulacb-backups",
    "retention_days": 7,
    "compression": true,
    "encryption": false,
    "timeout": 1800000000000
  },
  "migration": {
    "workers": 8,
    "batch_size": 1000,
    "retry_attempts": 3,
    "validate_after": true
  },
  "ai": {
    "enabled": true,
    "provider": "ollama",
    "model": "llama3",
    "api_endpoint": "http://127.0.0.1:11434",
    "api_key": "",
    "max_tokens": 4096,
    "auto_analyze": false
  },
  "docker": {
    "enabled": false,
    "host": "unix:///var/run/docker.sock",
    "network": "nebulacb-net"
  }
